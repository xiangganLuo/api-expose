<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.api.expose.system.dal.mysql.dept.PostMapper">

    <!-- 根据业务表查询实际使用的岗位 -->
    <select id="selectPostsByTable" resultType="com.api.expose.system.dal.dataobject.dept.PostDO">
        SELECT DISTINCT p.*
        FROM system_post p
        INNER JOIN ${tableName} t ON p.id = t.post_id
        WHERE p.status = 0 
          AND p.deleted = 0 
          AND t.deleted = 0
        ORDER BY p.sort ASC
    </select>

</mapper>
