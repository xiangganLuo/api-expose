<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.api.expose.infrastructure.dao.IApiVersionDao">

    <resultMap id="apiVersionMap" type="com.api.expose.infrastructure.dao.po.ApiVersionPO">
        <id column="id" property="id"/>
        <result column="asset_id" property="assetId"/>
        <result column="version" property="version"/>
        <result column="active" property="active"/>
        <result column="release_note" property="releaseNote"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="queryByAssetId" parameterType="java.lang.Long" resultMap="apiVersionMap">
        SELECT id, asset_id, version, active, release_note, create_time
        FROM api_version
        WHERE asset_id = #{assetId}
    </select>

    <update id="resetActiveByAssetId" parameterType="java.lang.Long">
        UPDATE api_version SET active = 0 WHERE asset_id = #{assetId}
    </update>

</mapper>
